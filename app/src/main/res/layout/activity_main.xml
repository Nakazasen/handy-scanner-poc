<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <!-- Camera Preview View -->
    <androidx.camera.view.PreviewView
        android:id="@+id/viewFinder"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Dấu thập đỏ (Viewfinder nhỏ) hỗ trợ ngắm -->
    <View
        android:id="@+id/center_line"
        android:layout_width="0dp"
        android:layout_height="2dp"
        android:layout_marginHorizontal="32dp"
        android:background="#FF0000"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Nút chọn ngôn ngữ (Globe) -->
    <ImageButton
        android:id="@+id/btnLanguage"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_margin="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_language"
        android:padding="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:tint="@color/white" />

    <!-- Khung điều khiển phía dưới -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/overlay_dark"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Label định dạng mã -->
        <TextView
            android:id="@+id/tvFormat"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:alpha="0.7"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            tools:text="Format: DATA_MATRIX" />

        <!-- Ô nhập liệu Textbox -->
        <EditText
            android:id="@+id/etResult"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@drawable/edit_text_background"
            android:hint="@string/hint_scan_result"
            android:padding="12dp"
            android:textColor="@color/scan_success"
            android:textSize="18sp"
            android:textStyle="bold"
            android:focusable="true"
            android:clickable="true"
            app:layout_constraintTop_toBottomOf="@id/tvFormat"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnScanTrigger" />

        <!-- Nút kích hoạt Scan (Icon) -->
        <ImageButton
            android:id="@+id/btnScanTrigger"
            android:layout_width="56dp"
            android:layout_height="0dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/button_scan_background"
            android:src="@android:drawable/ic_menu_camera"
            app:tint="@color/white"
            app:layout_constraintTop_toTopOf="@id/etResult"
            app:layout_constraintBottom_toBottomOf="@id/etResult"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Nút Xác nhận (Clear) -->
        <Button
            android:id="@+id/btnClear"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginTop="16dp"
            android:backgroundTint="@color/white"
            android:text="@string/btn_confirm_clear"
            android:textColor="@color/black"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/etResult"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
